<Window x:Class="NetSpeedMonitor.SpeedWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        ResizeMode="NoResize"
        Width="180" Height="36"
        FontFamily="Segoe UI"
        Icon="pack://application:,,,/app_logo.png"
        MouseDoubleClick="Window_MouseDoubleClick">

    <Border x:Name="WidgetBorder" CornerRadius="18" Padding="12,2"
            BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0.3,1">
                <GradientStop Color="#CC121225" Offset="0"/>
                <GradientStop Color="#CC1a1a35" Offset="0.5"/>
                <GradientStop Color="#CC141430" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#40FFFFFF" Offset="0"/>
                <GradientStop Color="#15FFFFFF" Offset="0.5"/>
                <GradientStop Color="#25FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="10"
                             ShadowDepth="1" Opacity="0.5" Direction="270"/>
        </Border.Effect>

        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Download -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="↓" FontSize="12" FontWeight="Bold" Foreground="#00D2FF" VerticalAlignment="Center" Margin="0,-2,2,0"/>
                <TextBlock x:Name="DownloadText" Text="0 B/s" FontSize="11" FontWeight="Bold" Foreground="#00D2FF" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Small divider -->
            <Border Grid.Column="1" Width="1" Height="14" Background="#20FFFFFF" Margin="6,0"/>

            <!-- Upload -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="↑" FontSize="12" FontWeight="Bold" Foreground="#FFA500" VerticalAlignment="Center" Margin="0,-2,2,0"/>
                <TextBlock x:Name="UploadText" Text="0 B/s" FontSize="11" FontWeight="Bold" Foreground="#FFA500" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
