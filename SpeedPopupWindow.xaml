<Window x:Class="NetSpeedMonitor.SpeedPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Width="340" Height="500"
        FontFamily="Segoe UI"
        Icon="pack://application:,,,/app_logo.png">

    <Border x:Name="MainBorder" CornerRadius="16" Margin="10"
            BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0.3,1">
                <GradientStop Color="#F0121225" Offset="0"/>
                <GradientStop Color="#F01a1a35" Offset="0.5"/>
                <GradientStop Color="#F0141430" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#40FFFFFF" Offset="0"/>
                <GradientStop Color="#15FFFFFF" Offset="0.5"/>
                <GradientStop Color="#25FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="25"
                             ShadowDepth="2" Opacity="0.7" Direction="270"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform"/>
        </Border.RenderTransform>

        <Grid Margin="24,20,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="130"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ Title Bar ═══ -->
            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="⚡" FontSize="18" VerticalAlignment="Center"/>
                    <TextBlock Text=" Net Speed" FontSize="16" FontWeight="SemiBold"
                             Foreground="#DDFFFFFF" VerticalAlignment="Center" Margin="2,0,0,0"/>
                </StackPanel>

                <!-- LIVE indicator with pulsing glow -->
                <Border Grid.Column="2" CornerRadius="4" Padding="8,3"
                        Background="#22FF3333" BorderBrush="#44FF3333" BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="LiveIndicator" Text="● LIVE" FontSize="9" FontWeight="Bold"
                             Foreground="#FFFF4444">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            From="1" To="0.35" Duration="0:0:0.9"
                                            AutoReverse="True">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                </Border>
            </Grid>

            <!-- ═══ Download Speed Card ═══ -->
            <Border Grid.Row="1" CornerRadius="12" Padding="16,14" Margin="0,0,0,8"
                    BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#1800D2FF" Offset="0"/>
                        <GradientStop Color="#0800D2FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#2800D2FF"/>
                </Border.BorderBrush>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                    </Grid.RowDefinitions>

                    <!-- Arrow -->
                    <Border Grid.Column="0" Grid.RowSpan="3" CornerRadius="8"
                            Width="38" Height="38" Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3000D2FF" Offset="0"/>
                                <GradientStop Color="#1500D2FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="↓" FontSize="22" Foreground="#00D2FF"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Margin="0,-2,0,0"/>
                    </Border>

                    <!-- Label -->
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="DOWNLOAD" FontSize="10"
                             Foreground="#7799BBDD" FontWeight="SemiBold"/>

                    <!-- Speed value -->
                    <TextBlock x:Name="DownloadSpeedText" Grid.Column="1" Grid.Row="1"
                             Text="0 B/s" FontSize="22" FontWeight="Bold"
                             Foreground="#00D2FF" Margin="0,-3,0,0"/>

                    <!-- Session total -->
                    <StackPanel Grid.Column="2" Grid.RowSpan="3" VerticalAlignment="Center">
                        <TextBlock Text="TOTAL" FontSize="8" Foreground="#4499BBDD"
                                 HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        <TextBlock x:Name="DownloadTotalText" Text="0 B" FontSize="11"
                                 Foreground="#6600D2FF" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ Upload Speed Card ═══ -->
            <Border Grid.Row="2" CornerRadius="12" Padding="16,14" Margin="0,0,0,18"
                    BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#18FFA500" Offset="0"/>
                        <GradientStop Color="#08FFA500" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#28FFA500"/>
                </Border.BorderBrush>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                    </Grid.RowDefinitions>

                    <!-- Arrow -->
                    <Border Grid.Column="0" Grid.RowSpan="3" CornerRadius="8"
                            Width="38" Height="38" Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#30FFA500" Offset="0"/>
                                <GradientStop Color="#15FFA500" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="↑" FontSize="22" Foreground="#FFA500"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Margin="0,-2,0,0"/>
                    </Border>

                    <!-- Label -->
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="UPLOAD" FontSize="10"
                             Foreground="#77DDBB88" FontWeight="SemiBold"/>

                    <!-- Speed value -->
                    <TextBlock x:Name="UploadSpeedText" Grid.Column="1" Grid.Row="1"
                             Text="0 B/s" FontSize="22" FontWeight="Bold"
                             Foreground="#FFA500" Margin="0,-3,0,0"/>

                    <!-- Session total -->
                    <StackPanel Grid.Column="2" Grid.RowSpan="3" VerticalAlignment="Center">
                        <TextBlock Text="TOTAL" FontSize="8" Foreground="#44DDBB88"
                                 HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        <TextBlock x:Name="UploadTotalText" Text="0 B" FontSize="11"
                                 Foreground="#66FFA500" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ Speed History Header ═══ -->
            <Grid Grid.Row="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="SPEED HISTORY" FontSize="10"
                         Foreground="#5599AABB" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="60s" FontSize="10"
                         Foreground="#3399AABB"/>
            </Grid>

            <!-- ═══ Speed Graph ═══ -->
            <Border Grid.Row="4" CornerRadius="10" Padding="8"
                    Margin="0,0,0,18" BorderThickness="1">
                <Border.Background>
                    <SolidColorBrush Color="#0CFFFFFF"/>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#12FFFFFF"/>
                </Border.BorderBrush>
                <Canvas x:Name="GraphCanvas" ClipToBounds="True"/>
            </Border>

            <!-- ═══ Session Stats Row ═══ -->
            <Grid Grid.Row="5" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="SESSION ↓" FontSize="9" Foreground="#4499AABB" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SessionDownText" Text="0 B" FontSize="15"
                             Foreground="#9900D2FF" FontWeight="SemiBold" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Divider -->
                <Border Grid.Column="1" Width="1" Background="#1AFFFFFF"
                        Margin="16,2,16,2"/>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="SESSION ↑" FontSize="9" Foreground="#4499AABB" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SessionUpText" Text="0 B" FontSize="15"
                             Foreground="#99FFA500" FontWeight="SemiBold" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ═══ Duration ═══ -->
            <Border Grid.Row="6" CornerRadius="8" Padding="12,8" Margin="0,0,0,10"
                    Background="#08FFFFFF" BorderBrush="#0EFFFFFF" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="⏱" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="Session Duration" FontSize="11"
                             Foreground="#6699AABB" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DurationText" Grid.Column="2" Text="0s" FontSize="11"
                             Foreground="#9999BBDD" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ═══ Adapter Info ═══ -->
            <Border Grid.Row="7" CornerRadius="8" Padding="12,8"
                    Background="#08FFFFFF" BorderBrush="#0EFFFFFF" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🌐" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="AdapterText" Text="Detecting adapter..." FontSize="11"
                             Foreground="#5599AABB" VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" MaxWidth="240"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
